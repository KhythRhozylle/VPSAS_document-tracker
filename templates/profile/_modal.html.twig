{% set profilePictureUrl = profilePictureUrl ?? null %}

<div class="profile-modal-content">
    <div class="profile-header">
        <div class="profile-avatar-wrap">
            <div class="profile-avatar" id="profile-avatar-preview">
                {% if profilePictureUrl %}
                    <img src="{{ profilePictureUrl ~ '?v=' ~ user.updatedAt|date('U') }}" alt="{{ user.fullName }}" id="profile-avatar-img">
                {% else %}
                    <span class="profile-avatar-initials" id="profile-avatar-initials">{{ user.initials }}</span>
                {% endif %}
            </div>
            <button type="button" class="profile-avatar-edit" id="profile-avatar-edit-btn" title="Change photo">
                <i class="bi bi-camera"></i>
            </button>
        </div>
        <div class="profile-header-info">
            <h6 class="profile-name" id="profile-display-name">{{ user.fullName }}</h6>
            <p class="profile-meta" id="profile-display-email">{{ user.email }}</p>
            <p class="profile-meta mb-0">{{ user.getPrimaryRoleLabel() }}{% if user.jobTitle %} · {{ user.jobTitle }}{% endif %}</p>
        </div>
    </div>

    {{ form_start(form, {
        action: path('app_profile_update'),
        method: 'POST',
        multipart: true,
        attr: {
            id: 'profile-form',
            novalidate: 'novalidate',
        }
    }) }}
        <div class="row g-3">
            <div class="col-md-6">
                {{ form_row(form.firstName, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.lastName, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.email, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.phone, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.department, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.jobTitle, { attr: { class: 'form-control' } }) }}
            </div>
            <div class="col-12 profile-file-field">
                {{ form_widget(form.profilePictureFile, {
                    attr: {
                        class: 'form-control d-none',
                        id: 'profile_picture_file',
                        accept: 'image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp',
                    }
                }) }}
                <label for="profile_picture_file" class="btn btn-outline-soft btn-sm">
                    <i class="bi bi-upload me-1"></i> Choose Profile Picture
                </label>
                <span class="profile-file-name text-muted ms-2" id="profile-file-name">No file chosen</span>
                <small class="text-muted d-block mt-1">JPG, JPEG, PNG, or WEBP. Max 5 MB.</small>
            </div>
            <div class="col-md-6">
                {{ form_row(form.plainPassword.first, { attr: { class: 'form-control', autocomplete: 'new-password' } }) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.plainPassword.second, { attr: { class: 'form-control', autocomplete: 'new-password' } }) }}
            </div>
        </div>

        <div class="profile-details mt-4 pt-3 border-top border-secondary-subtle">
            <div class="detail-row">
                <span class="detail-label">Member since</span>
                <span class="detail-value">{{ user.createdAt|date('M d, Y') }}</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Last updated</span>
                <span class="detail-value" id="profile-updated-at">{{ user.updatedAt|date('M d, Y h:i A') }}</span>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button type="button" class="btn btn-outline-soft" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary-gradient" id="profile-save-btn">
                <i class="bi bi-check-lg me-1"></i> Save Profile
            </button>
        </div>
    {{ form_end(form) }}
</div>

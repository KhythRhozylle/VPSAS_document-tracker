{{ form_start(form, { action: path('app_documents_edit', { id: document.id }), attr: { id: 'document-edit-form', class: 'document-edit-form' } }) }}
    <div class="row g-3">
        <div class="col-md-6">{{ form_row(form.dateApproved) }}</div>
        <div class="col-md-6">{{ form_row(form.campus) }}</div>
        <div class="col-md-6">{{ form_row(form.documentType) }}</div>
        <div class="col-md-6">{{ form_row(form.amount) }}</div>
        <div class="col-12">{{ form_row(form.particulars) }}</div>
        <div class="col-12">{{ form_row(form.nature) }}</div>
    </div>
    <div class="d-flex justify-content-end gap-2 mt-3">
        <button type="button" class="btn btn-outline-soft" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary-gradient">Save Changes</button>
    </div>
{{ form_end(form) }}

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}VPSAS Monitoring & Tracking System{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📄</text></svg>">
        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
        <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
            <i class="bi bi-list"></i>
        </button>
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <div class="d-flex" id="app-root">
            <nav id="sidebar">
                {% block sidebar %}
                <div class="sidebar-brand">
                    <div class="sidebar-brand-icon">
                        <img src="{{ asset('images/logo.png') }}" alt="VPSAS Logo">
                    </div>
                    <div class="sidebar-brand-text">
                        <h5>VPSAS</h5>
                        <small>Document Tracker</small>
                    </div>
                </div>
                <ul class="sidebar-nav">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_dashboard' or app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}"
                           href="{{ path('app_dashboard') }}">
                            <i class="bi bi-house-door"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_documents' ? 'active' : '' }}"
                           href="{{ path('app_documents') }}">
                            <i class="bi bi-table"></i>
                            Documents
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_reports' ? 'active' : '' }}"
                           href="{{ path('app_reports') }}">
                            <i class="bi bi-credit-card"></i>
                            Reports
                        </a>
                    </li>
                    {% if isAdmin %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_activity_logs' ? 'active' : '' }}"
                           href="{{ path('app_activity_logs') }}">
                            <i class="bi bi-journal-text"></i>
                            Activity Logs
                        </a>
                    </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_help' ? 'active' : '' }}"
                           href="{{ path('app_help') }}">
                            <i class="bi bi-question-circle"></i>
                            Help Center
                        </a>
                    </li>
                </ul>

                <div class="sidebar-section-label">Account Pages</div>
                <ul class="sidebar-nav sidebar-nav-secondary">
                    <li class="nav-item">
                        <a class="nav-link" href="#" id="sidebar-profile-link">
                            <i class="bi bi-person"></i>
                            Profile
                        </a>
                    </li>
                    {% if currentUser %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right"></i>
                            Sign Out
                        </a>
                    </li>
                    {% else %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right"></i>
                            Sign In
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_register') }}">
                            <i class="bi bi-person-plus"></i>
                            Sign Up
                        </a>
                    </li>
                    {% endif %}
                </ul>

                <div class="sidebar-help-card">
                    <div class="sidebar-help-card-bg"></div>
                    <div class="sidebar-help-card-content">
                        <p class="sidebar-help-title">Need help?</p>
                        <p class="sidebar-help-text">Visit the Help Center for guides and FAQs</p>
                        <a href="{{ path('app_help') }}" class="btn btn-sidebar-docs">HELP CENTER</a>
                    </div>
                </div>
                {% endblock %}
            </nav>

            <main class="flex-fill content-area">
                {% include '_navbar.html.twig' %}

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </main>
        </div>

        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="app-toast" class="toast align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body"></div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>

        {% block page_scripts %}{% endblock %}
    </body>
</html>
